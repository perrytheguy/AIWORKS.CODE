# ============================================================
#  AIWORKS.CODE - Configuration File
#  Format: INI-style (Key = Value), # comments supported
# ============================================================

[AI]
Provider = custom
LoginUrl = https://internal-ai.company.com/login
Endpoint = https://internal-ai.company.com/api/chat
CookieField = bearer_token
AuthToken =
Model = internal-llm
MaxTokens = 4096
TimeoutSec = 60
MaxHistory = 20
SystemPrompt = You are AIWORKS, a local AI agent for Windows PowerShell in a corporate intranet. ALWAYS respond in strict JSON only: {"action":"...","params":{...},"message":"...","requires_confirmation":false}. Never suggest code - always perform direct actions. Users can also run actions directly via the /run command without AI involvement. Available actions and their required params: [answer] params: {message(string,required)} - reply with text; [shell] params: {command(string,required), workdir(string,optional), timeout(int,optional,default=60)} - execute PowerShell command; [chrome] params: {action(open|navigate|screenshot|script,required), url(string,required), selector(string,optional), script(string,optional)} - control Chrome browser; [office] params: {app(excel|word|ppt,required), action(open|read|new|save|close|pdf,required), path(string,optional), sheet(string,optional), range(string,optional)} - control Microsoft Office; [ie] params: {action(open|read|input|click|wait|close,required), url(string,optional), selector(string,optional), value(string,optional), timeout(int,optional)} - control Internet Explorer; [hwp] params: {action(open|read|new|save|pdf|close,required), path(string,optional)} - control Hangul Word Processor; [pdf] params: {path(string,required), action(read|info,optional,default=read), maxchars(int,optional,default=3000)} - read PDF files. Choose the action that best fulfills the user request and populate all required params.

[Browser]
ChromeExePath = C:\Program Files\Google\Chrome\Application\chrome.exe
ChromeDriverPath = C:\drivers\chromedriver.exe
PlaywrightCLI = npx playwright
EnableIE = true

[Office]
HwpSecurityPath = C:\Users\Public\Documents\HNCPaper\hwp
PdfExtractTool = pdftotext
PdfToolPath =
ComInitDelayMs = 1500

[Safety]
ConfirmKeywords = delete,drop,format,remove,rm,shutdown,삭제
LogDangerousActions = true
LogPath = .\aiworks.log

[UI]
Prompt = AIWORKS
ShowThinking = true
ColorOutput = true

[Programs]
Excel = C:\Program Files\Microsoft Office\root\Office16\EXCEL.EXE
Word = C:\Program Files\Microsoft Office\root\Office16\WINWORD.EXE
PowerPoint = C:\Program Files\Microsoft Office\root\Office16\POWERPNT.EXE
HWP = C:\Program Files (x86)\HNC\Office NEO\HOffice9\Bin\Hwp.exe
Chrome = C:\Program Files\Google\Chrome\Application\chrome.exe
Edge = C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
Notepad = C:\Windows\System32\notepad.exe

[Warnings]
delete = 파일 또는 데이터를 영구 삭제합니다. 이 작업은 되돌릴 수 없습니다.
drop = 데이터베이스 테이블 또는 구조가 삭제됩니다. 신중하게 진행하세요.
format = 드라이브 또는 셀 포맷이 실행됩니다. 기존 데이터가 손실될 수 있습니다.
remove = 항목을 제거합니다. 복구가 불가능할 수 있습니다.
rm = 파일 삭제 명령입니다. 복구가 불가능할 수 있습니다.
shutdown = 시스템 종료 명령입니다. 저장되지 않은 작업이 있으면 먼저 저장하세요.
삭제 = 삭제 작업은 되돌릴 수 없습니다. 신중하게 진행하세요.
